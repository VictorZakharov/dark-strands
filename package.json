{
  "name": "dark-strands-prototype",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "A real-time 3D rendering & engine tech demo built with Babylon.js 9 (WebGPU/WebGL2).",
  "homepage": "https://darkst.netlify.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/VictorZakharov/dark-strands.git"
  },
  "scripts": {
    "start": "npx serve . -p 3000 --no-clipboard",
    "dev": "npx serve . -p 3000 --no-clipboard",
    "bundle:babylon": "node scripts/bundle-babylon.js",
    "bundle:eztree": "node scripts/bundle-eztree.js",
    "build": "node build.js",
    "serve:prod": "node build.js && npx serve dist -p 3000 --no-clipboard",
    "count": "node count_lines.mjs"
  },
  "dependencies": {
    "@babylonjs/core": "^9.17.0",
    "@babylonjs/havok": "^1.3.11",
    "@babylonjs/loaders": "^9.17.0",
    "@babylonjs/materials": "^9.17.0",
    "@dgreenheck/ez-tree": "^1.1.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "esbuild": "^0.27.3"
  }
}
